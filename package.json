{
  "name": "@yaohaixiao/tetris.js",
  "version": "0.3.0",
  "description": "tetris.js - 一款 JavaScript 开发的仿 FC 经典俄罗斯方块游戏",
  "main": "tetris.html",
  "scripts": {
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "build:formatted": "node build/build.js action=format",
    "build": "node build/build.js action=minify",
    "format": "npm run format:es && npm run format:prettier",
    "format:es": "eslint . --fix",
    "format:prettier": "npm run format:prettier:raw -- --write",
    "format:prettier:raw": "prettier \"**/*.{{m,c,}{j,t}s{x,},md{x,},json,y{a,}ml}\" --ignore-path .gitignore",
    "lint": "npm run lint:es && npm run lint:prettier",
    "lint:es": "eslint .",
    "lint:prettier": "npm run format:prettier:raw -- --check",
    "test": "npm run format && npm run test:unit",
    "test:unit": "jest --config jest.config.js",
    "prepare": "husky install"
  },
  "keywords": [
    "javascript",
    "tetris",
    "game",
    "tetris.js"
  ],
  "author": "乘风巨浪",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaohaixiao/tetris.js.git"
  },
  "bugs": {
    "url": "https://github.com/yaohaixiao/tetris.js/issues"
  },
  "homepage": "https://github.com/yaohaixiao/tetris.js#readme",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@imgix/js-core": "^3.8.0",
    "babel-jest": "^30.2.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "chalk": "^5.6.2",
    "commitlint": "^20.3.1",
    "conventional-changelog-cli": "^5.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-jest": "^3.0.2",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.0.0",
    "html-minifier-terser": "^7.2.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-html-reporter": "^4.3.0",
    "less": "^4.6.4",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0"
  },
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ],
    "plugins": [
      [
        "babel-plugin-transform-import-meta",
        {
          "module": "ES6"
        }
      ]
    ]
  },
  "prettier": {
    "plugins": [
      "./node_modules/prettier-plugin-jsdoc/dist/index.js"
    ],
    "proseWrap": "always",
    "singleQuote": true,
    "tabWidth": 2
  },
  "gitHooks": {
    "pre-commit": "lint-staged",
    "commit-msg": "commitlint"
  },
  "lint-staged": {
    "utils/*.js": [
      "npm run format:es",
      "npm run format:prettier"
    ]
  }
}
